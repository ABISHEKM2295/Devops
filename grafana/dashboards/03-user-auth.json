{
  "title": "3 \u2014 User and Auth",
  "uid": "crowdfundin-user-auth",
  "tags": [
    "crowdfundin",
    "auth",
    "users"
  ],
  "refresh": "1m",
  "schemaVersion": 38,
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "annotations": {
    "list": []
  },
  "templating": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "title": "New Registrations Per Day (Last 30 Days)",
      "type": "barchart",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "expr": "increase(crowdfundin_user_registrations_total[1d])",
          "legendFormat": "New Registrations",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineWidth": 1
          }
        }
      },
      "options": {
        "barWidth": 0.6,
        "groupWidth": 0.7
      }
    },
    {
      "id": 2,
      "title": "Login Failure Rate (per minute)",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "expr": "rate(crowdfundin_login_failures_total[1m]) * 60",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "unit": "short",
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 10
              },
              {
                "color": "red",
                "value": 50
              }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "graphMode": "area"
      },
      "alert": {
        "name": "Login Failures Alert",
        "message": "Login failures exceeding 50/min \u2014 possible brute force",
        "conditions": [
          {
            "type": "query",
            "query": {
              "params": [
                "A",
                "2m",
                "now"
              ]
            },
            "reducer": {
              "type": "last"
            },
            "evaluator": {
              "type": "gt",
              "params": [
                50
              ]
            }
          }
        ],
        "executionErrorState": "alerting",
        "for": "2m",
        "frequency": "1m",
        "noDataState": "no_data"
      }
    },
    {
      "id": 3,
      "title": "Login Failure Trend (Last 24h)",
      "type": "timeseries",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "expr": "rate(crowdfundin_login_failures_total[5m]) * 60",
          "legendFormat": "Failures/min",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "fixedColor": "red",
            "mode": "fixed"
          },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 20
          },
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 50
              }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Login Success Rate (Last 24h)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "expr": "(sum(rate(http_requests_total{route=~\"/api/auth/login\",status=\"200\"}[5m])) or vector(0)) / clamp_min(sum(rate(http_requests_total{route=~\"/api/auth/login\"}[5m])), 0.001) * 100",
          "legendFormat": "Login Success %",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          },
          "min": 0,
          "max": 100
        }
      }
    },
    {
      "id": 5,
      "title": "Total Registered Users (All Time)",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "expr": "crowdfundin_user_registrations_total",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "graphMode": "none"
      }
    },
    {
      "id": 6,
      "title": "Total Login Failures (All Time)",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "expr": "crowdfundin_login_failures_total",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 100
              }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "graphMode": "none"
      }
    }
  ]
}